# Django core
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DEBUG=True

# --- Database ---
# In Docker, the web service connects to the bundled `db` Postgres service
# using these variables. Outside Docker, leaving them unset falls back to
# the SQLite file at DATABASE_PATH (or BASE_DIR/db.sqlite3).
POSTGRES_DB=lms
POSTGRES_USER=lms
POSTGRES_PASSWORD=lms
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Alternatively, set a single DATABASE_URL (takes precedence over POSTGRES_*):
# DATABASE_URL=postgres://lms:lms@db:5432/lms

# Used only for SQLite fallback (no Postgres env vars set):
DATABASE_PATH=/data/db.sqlite3

# Initial superadmin bootstrap (used on container start).
# If both are set AND no Admin exists with this email, an admin record is
# created automatically. Re-running compose will NOT overwrite an existing
# admin or change its password.
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me-on-first-login
INITIAL_ADMIN_NAME=Initial Admin

# Email / SMTP (leave EMAIL_HOST_PASSWORD blank to fall back to console backend)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.mailgun.org
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=LMS-Info <noreply@library.com>
